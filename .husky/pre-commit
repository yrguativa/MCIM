#!/bin/sh

# Only run checks if there are staged files
if git diff --cached --quiet; then
  exit 0
fi

echo "🔍 Running pre-commit checks..."

# Ensure common paths are available
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/local/sbin:/usr/bin:/bin:$PATH"

# Find pnpm - try multiple methods
PNPM_CMD=""
if command -v pnpm >/dev/null 2>&1; then
  PNPM_CMD="pnpm"
elif [ -x "/opt/homebrew/bin/pnpm" ]; then
  PNPM_CMD="/opt/homebrew/bin/pnpm"
elif [ -x "/usr/local/bin/pnpm" ]; then
  PNPM_CMD="/usr/local/bin/pnpm"
fi

# If pnpm not found, skip checks (allow commit)
if [ -z "$PNPM_CMD" ]; then
  echo "⚠️ pnpm not found. Skipping pre-commit checks. Install pnpm to enable automatic validation."
  exit 0
fi

# Check if frontend files changed - only lint, don't fail on warnings
if git diff --cached --name-only | grep -q "^app/"; then
  echo "🧹 Linting frontend..."
  (cd app && "$PNPM_CMD" run lint) || true
fi

# Check if backend files changed
if git diff --cached --name-only | grep -q "^cells-back/"; then
  echo "🔨 Building backend..."
  (cd cells-back && "$PNPM_CMD" run build) || true
fi

echo "✅ Pre-commit checks completed!"
exit 0
