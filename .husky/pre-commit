#!/bin/sh

# Only run checks if there are staged files
if git diff --cached --quiet; then
  exit 0
fi

echo "🔍 Running pre-commit checks..."

# Ensure common paths are available
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/local/sbin:/usr/bin:/bin:$PATH"

# Check if backend files changed
if git diff --cached --name-only | grep -q "^cells-back/"; then
  echo "🔨 Building backend..."
  cd cells-back && npm run build 2>/dev/null
  BUILD_RESULT=$?
  cd ..
  
  if [ $BUILD_RESULT -ne 0 ] && [ $BUILD_RESULT -ne 127 ]; then
    echo "❌ Backend build failed"
    exit 1
  fi
  
  if [ $BUILD_RESULT -eq 127 ]; then
    echo "⚠️ npm not available in Git hook environment. Skipping backend build."
  fi
fi

# Check if frontend files changed
if git diff --cached --name-only | grep -q "^app/"; then
  echo "🧹 Linting frontend..."
  cd app && npm run lint 2>/dev/null
  LINT_RESULT=$?
  cd ..
  
  if [ $LINT_RESULT -ne 0 ] && [ $LINT_RESULT -ne 127 ]; then
    echo "❌ Frontend lint failed"
    exit 1
  fi
  
  if [ $LINT_RESULT -eq 127 ]; then
    echo "⚠️ npm not available in Git hook environment. Skipping frontend lint."
  fi
fi

echo "✅ Pre-commit checks passed!"
